{
  "rules": {
    "rooms": {
      "$room": {
        "messages": {
          ".read": true,
          ".write": true,
          "$msg": {
            ".validate": "newData.hasChildren(['c','ts'])",
            "c":  { ".validate": "newData.isString() && newData.val().length < 8000" },
            "ts": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },
        "seats": {
          ".read": true,
          ".write": true,
          "$device": {
            ".validate": "newData.hasChildren(['name','ts'])",
            "name": { ".validate": "newData.isString() && newData.val().length < 60" },
            "ts":   { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        }
      }
    }
  }
}
